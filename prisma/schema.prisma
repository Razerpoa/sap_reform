generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  
}

enum UserRole {
  WHITELISTED
  ADMIN
}

model User {
  id    String   @id @default(cuid())
  email String   @unique
  name  String?
  role  UserRole @default(WHITELISTED)
}

model CageMaster {
  id          String   @id @default(cuid())
  kandang     String   @unique
  jmlAyam     Int      @default(0)
  jmlEmber    Float    @default(0)
  jmlPakan    Float    @default(0)
  gramEkor    Float    @default(0)
  beratPakan  Float    @default(0)
  volEmber    Float?   @default(0)
  hargaPakan  Float?   @default(0)
  hargaSentral Float   @default(0)
  mortality   Int      @default(0)
  faktorPakan Float   @default(13)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Production {
  date          DateTime  @id @db.Date
  cageMasterId  String?  @default("default")
  cageData      Json     @default("{}")
  cageSummary  Json     @default("{}")
  up            Float    @default(0)
  operasional  Float    @default(0)
  profitDaily  Float    @default(0)
  createdAt     DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@index([date])
}

model Worker {
  id        String    @id @default(cuid())
  name      String    @unique
  active    Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model CashFlow {
  id               String   @id @default(cuid())
  date             DateTime @db.Date
  totalPenjualan   Float    @default(0)
  biayaPakan       Float    @default(0)
  biayaOperasional Float    @default(0)
  salaries         Json     @default("{}")
  devidenA         Float    @default(0)
  devidenB         Float    @default(0)
  saldoKas         Float    @default(0)
  saldoPemasukan   Float    @default(0)
  saldoKewajiban   Float    @default(0)
  saldoRekening    Float    @default(0)
  saldoCash        Float    @default(0)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([date])
}

model Sales {
  id               String   @id @default(cuid())
  date             DateTime @db.Date
  customerName     String
  jmlPeti          Float    @default(0)
  totalKg          Float    @default(0)
  hargaSentral     Float?   @default(0)
  up               Float    @default(0)
  hargaJual        Float    @default(0)
  subTotal         Float    @default(0)
  totalKgHariIni   Float?   @default(0)
  totalPetiHariIni Float?   @default(0)
  penjualanHariIni Float?   @default(0)
  totalProduksi    Float?   @default(0)
  stockAkhir       Float?   @default(0)
  sourceCages      Json      @default("[]")
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([date])
  @@index([customerName])
}

model OtherExpense {
  id          String   @id @default(cuid())
  date        DateTime @db.Date
  amount     Float
  description String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([date])
}

model CageStock {
  id           String   @id @default(cuid())
  date         DateTime @db.Date
  kandang      String
  openingKg    Float   @default(0)
  productionKg Float   @default(0)
  soldKg      Float   @default(0)
  closingKg   Float   @default(0)
  createdAt   DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([date, kandang])
  @@index([date])
}

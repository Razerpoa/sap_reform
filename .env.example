# Database Configuration
# Replace 'password' and 'sap_reform' with your local settings
DATABASE_HOST="db"
DATABASE_PASSWORD=password
DATABASE_USERNAME=postgres

# NextAuth Configuration
# For local development: http://localhost:3000
NEXTAUTH_URL=""
# Generate a secret via 'openssl rand -base64 32'
NEXTAUTH_SECRET=""

# Google OAuth Credentials
# Obtain these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Access Control
# Comma-separated list of authorized email addresses
ALLOWED_EMAILS=""

# Super Admin (can edit faktorPakan)
SUPER_ADMIN_EMAIL=admin@example.com
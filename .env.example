# Database Configuration
# Replace 'password' and 'sap_reform' with your local settings
DATABASE_HOSTNAME="db"
DATABASE_URL="postgresql://postgres:password@${DATABASE_HOSTNAME}:5432/database_name?schema=public"

# NextAuth Configuration
# For local development: http://localhost:3000
NEXTAUTH_URL=""
# Generate a secret via 'openssl rand -base64 32'
NEXTAUTH_SECRET=""

# Google OAuth Credentials
# Obtain these from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Access Control
# Comma-separated list of authorized email addresses
ALLOWED_EMAILS=""